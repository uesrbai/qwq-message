# 复制本文件为 .env 并按需填写。 cp .env.example .env

# ===== 数据库 =====
# 本地开发：SQLite（一个文件，零安装）
DATABASE_URL="file:./dev.db"
# 部署到 Zeabur 等平台：改成 PostgreSQL 连接串（并按 README 把 schema 的 provider 改为 postgresql）
# DATABASE_URL="postgres://user:password@host:5432/dbname"

# ===== 登录会话签名密钥（必填！生产环境务必换成随机值）=====
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-random-64-char-hex-string"

# ===== 应用访问地址 =====
APP_URL="http://localhost:3000"

# ===== qwq-sso 单点登录（可选，不用可留空/删除）=====
# SSO 服务地址（不含末尾斜杠）
# QWQ_SSO_BASE_URL="https://qwqsso.zeabur.app"
# 分配给本应用的 API Key（沙盒 sk_test_ / 生产 sk_live_）
# QWQ_SSO_API_KEY=""
# 新用户经 SSO 首次登录时的角色（默认 ADMIN）
# QWQ_SSO_DEFAULT_ROLE="ADMIN"
# 仅允许这些邮箱经 SSO 登录（逗号分隔；留空=允许任何有效用户）
# QWQ_SSO_ALLOWED_EMAILS=""
